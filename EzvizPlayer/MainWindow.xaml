<Window x:Class="EzvizPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="配送系统视频监控" Height="720" Width="1280" Icon="icon.ico"
        Background="#FF051020" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFC0C0D0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2A2A3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFD0D0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CornerRadius="0"
                      CaptionHeight="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#FF1E3A6B" BorderThickness="1" Background="#FF051020">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏：标题绝对居中 -->
            <Border x:Name="HeaderBar" Height="44" Background="#FF0B1D3D"
                    BorderBrush="#FF1E3A6B" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：图标 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="icon.ico" Width="20" Height="20" Margin="14,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：窗口控制按钮 + 刷新 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="RefreshButton" Content="&#xE72C;" Click="RefreshButton_Click"
                                Style="{StaticResource WindowButtonStyle}" ToolTip="刷新视频流"/>
                        <Button x:Name="MinimizeButton" Content="&#xE921;" Click="MinimizeButton_Click"
                                Style="{StaticResource WindowButtonStyle}" ToolTip="最小化"/>
                        <Button x:Name="MaximizeButton" Content="&#xE922;" Click="MaximizeButton_Click"
                                Style="{StaticResource WindowButtonStyle}" ToolTip="全屏"/>
                        <Button x:Name="CloseButton" Content="&#xE8BB;" Click="CloseButton_Click"
                                Style="{StaticResource CloseButtonStyle}" ToolTip="关闭"/>
                    </StackPanel>

                    <!-- 中间：标题绝对居中（横跨3列，鼠标事件穿透） -->
                    <StackPanel Grid.ColumnSpan="3" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock x:Name="HeaderTitle" Text="配送系统视频监控"
                                   Foreground="#FFF0F0F5" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="HeaderSubtitle" Text="0 路视频"
                                   Foreground="#FF8090B0" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 视频网格容器：完全随窗口拉伸 -->
            <Grid x:Name="VideoGrid" Grid.Row="1" Background="#FF051020" Margin="2">
                <!-- 动态添加 -->
            </Grid>


        </Grid>
    </Border>
</Window>
